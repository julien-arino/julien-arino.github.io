---
layout: page
---
<div class="post">
  <article>
    {% if site.data.people %}
      {% for profile in site.data.people %}
        {% if profile.current == "TRUE" or profile.current == true %}
          <hr>
          <div class="profile float-{% cycle 'left', 'right' %}">
            {% if profile.image and profile.image != "" %}
              {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
              {% if profile.image_circular == "TRUE" or profile.image_circular == true %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
              {% else %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
              {% endif %}
              {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
              {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=profile.image %}
            {% endif %}
            {% if profile.more_info and profile.more_info != "" %}
              <div class="more-info">{{ profile.more_info }}</div>
            {% endif %}
          </div>

          <div class="clearfix">
            {% if profile.content and profile.content != "" %}
              {% capture profile_content %}{% include {{ profile.content }} %}{% endcapture %}
              {% assign profile_content_parts = profile_content | split: '---' %}
              {% assign first_part = profile_content_parts[0] | strip %}
              {% if first_part == "" and profile_content_parts[1] contains "layout:" %}
                {% assign front_matter = profile_content_parts[1] | prepend: '---' | append: '---' %}
                {% assign profile_content = profile_content | remove_first: front_matter %}
              {% endif %}
              {{ profile_content | markdownify }}
            {% else %}
              {{ content }}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </article>
</div>
